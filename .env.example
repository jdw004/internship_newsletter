# Copy this file to `.env` for local development and fill in real values.
# In GitHub Actions, set these as repository Secrets instead (Settings -> Secrets and variables -> Actions).
# The bot runs fine with NO secrets set when using --dry-run (it just won't send anything).

# --- Email (Gmail) ---
# GMAIL_USER is the full Gmail address you send FROM.
# GMAIL_APP_PASSWORD is a 16-char Google "App Password" (NOT your normal password).
#   Create one at: https://myaccount.google.com/apppasswords  (requires 2FA enabled)
# EMAIL_TO is where the digest is delivered (can be the same address).
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_TO=you@gmail.com

# --- Discord (webhook) ---
# Create a webhook in the Discord channel, then paste the URL here locally or add
# it as the DISCORD_WEBHOOK_URL repository secret in GitHub Actions.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- Auto-apply: Gemini API (for per-job cover letters) ---
# Only used by the LOCAL apply tool (python -m src.apply). Get a key at
# https://aistudio.google.com/apikey. If unset, applications still go through
# without a cover letter.
GEMINI_API_KEY=...

# --- SMS (Twilio) — OPTIONAL, off by default ---
# Email-only is the default. To add SMS later, enable it in config/settings.yaml,
# uncomment twilio in requirements.txt, and set these:
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_FROM=+14155551234
# SMS_TO=+14155556789
